# Deepgram API key — get yours free at https://console.deepgram.com
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Anthropic API key — get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Supabase — database and auth (https://supabase.com)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Google OAuth — for "Continue with Google" on the login screen
# Create at: https://console.cloud.google.com/apis/credentials → OAuth 2.0 Client ID → Desktop app
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Set to 'development' while building, 'production' for release
NODE_ENV=development
